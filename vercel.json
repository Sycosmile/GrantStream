{
  "version": 2,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build", "config": { "distDir": "build/client" } },
    { "src": "__create/index.ts", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/__create/index.ts" },
    { "src": "/(.*)", "dest": "/build/client/$1" }
  ]
}